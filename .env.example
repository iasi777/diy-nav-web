NODE_ENV=development
APP_NAME=diy-nav-web
APP_PORT=8787

# SQLite. Docker Compose overrides these with volume paths.
DATABASE_PATH=./data/diy-nav.sqlite
BACKUP_DIR=./backups

# Existing new-api gateway. The base URL must include /v1.
AI_NEW_API_BASE_URL=
AI_NEW_API_KEY=
AI_DEFAULT_MODEL=

# Web development and deployment.
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8787
VITE_BASE=/
VITE_USE_HASH_ROUTER=false
TAILSCALE_IP=100.87.23.114
WEB_PORT=8090
